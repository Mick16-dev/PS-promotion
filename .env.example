## Local development
# Copy this file to `.env.local` and fill in values.
# Do NOT commit `.env.local`.
#
# Notes:
# - Prefer https:// endpoints if your n8n instance supports TLS (avoids mixed-content blocks when the app is served over HTTPS).
# - These variables are `NEXT_PUBLIC_*` because they are used in client-side fetch calls.

NEXT_PUBLIC_N8N_CREATE_SHOW_WEBHOOK=http://n8n-a4c84s8ogs0048s08gkgcw0c.34.41.73.152.sslip.io/webhook/create-show
NEXT_PUBLIC_N8N_SEND_REMINDER_WEBHOOK=http://n8n-a4c84s8ogs0048s08gkgcw0c.34.41.73.152.sslip.io/webhook/send-reminder

# Supabase (client + server via @supabase/ssr)
# Get these from Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

